# ── Server ──────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Database ────────────────────────────────────
DB_PATH=./data/patches.db

# ── Storage Backend ─────────────────────────────
STORAGE_TYPE=s3

# ── IDCloudHost S3 (is3.cloudhost.id) ───────────
S3_ENDPOINT=https://is3.cloudhost.id
S3_REGION=id-jkt-1
S3_BUCKET=moccipult-patches
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://moccipult-patches.is3.cloudhost.id
S3_PREFIX=patches

# ── Alternative: Local storage ──────────────────
# STORAGE_TYPE=local
# STORAGE_PATH=./patches-storage
# SERVER_URL=http://localhost:3000

# ── Auth ────────────────────────────────────────
API_KEY=
