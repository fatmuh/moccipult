# Environment Configuration
PORT=3000
HOST=0.0.0.0

# Database
DB_PATH=./data/patches.db

# ─── Storage Backend ───────────────────────────
# STORAGE_TYPE=local   → Local filesystem (default)
# STORAGE_TYPE=s3      → S3-compatible object storage
STORAGE_TYPE=local
STORAGE_PATH=./patches-storage

# ─── S3 / Object Storage (only if STORAGE_TYPE=s3) ───
# Works with: AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces, Wasabi
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=moccipult-patches
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_PUBLIC_URL=https://moccipult-patches.s3.amazonaws.com   (optional, auto-generated if not set)
# S3_PREFIX=patches                                            (optional)

# Server URL (used to generate download URLs for local storage)
SERVER_URL=http://localhost:3000

# API Key for admin operations (leave empty to disable auth)
API_KEY=
